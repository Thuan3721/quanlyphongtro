@model IEnumerable<HeThongQuanLyPhongTro.Models.HopDong>

@{
    ViewData["Title"] = "Hợp đồng của tôi";
    var khachHang = ViewBag.KhachHang as HeThongQuanLyPhongTro.Models.KhachHang;
}

<div class="space-y-5">
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Hợp đồng của tôi</h1>
            <p class="text-gray-500">Quản lý hợp đồng thuê phòng</p>
        </div>
        <div class="text-sm text-gray-500">
            Khách hàng: <span class="font-semibold">@khachHang?.HoTen</span>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 gap-4">
            @foreach (var item in Model)
            {
                var isActive = item.TrangThai == "Hiệu lực";
                var ngayConLai = (item.NgayKetThuc - DateTime.Now)?.Days ?? 0;

                <div class="bg-white rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-all">
                    <div class="p-5">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-3">
                                    <i class="fas fa-file-contract text-2xl @(isActive ? "text-green-500" : "text-gray-400")"></i>
                                    <div>
                                        <h3 class="font-semibold text-lg">Hợp đồng HĐ@item.MaHopDong</h3>
                                        <p class="text-sm text-gray-500">Phòng: @item.PhongNavigation?.TenPhong - @item.PhongNavigation?.CoSo?.TenCoSo</p>
                                    </div>
                                </div>

                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                                    <div>
                                        <span class="text-gray-500">Ngày bắt đầu:</span>
                                        <p class="font-medium">@item.NgayBatDau?.ToString("dd/MM/yyyy")</p>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Ngày kết thúc:</span>
                                        <p class="font-medium @(isActive && ngayConLai <= 30 ? "text-red-600" : "")">
                                            @item.NgayKetThuc?.ToString("dd/MM/yyyy")
                                        </p>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Tiền cọc:</span>
                                        <p class="font-medium">@item.TienCoc?.ToString("N0") đ</p>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Trạng thái:</span>
                                        @if (isActive)
                                        {
                                            <span class="inline-block px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                                Đang hiệu lực
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-block px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">
                                                Đã kết thúc
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div>
                                <a asp-action="HopDongChiTiet" asp-route-id="@item.MaHopDong"
                                   class="text-blue-500 hover:text-blue-700">
                                    <i class="fas fa-chevron-right"></i> Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm p-12 text-center">
            <i class="fas fa-file-contract text-gray-300 text-5xl mb-3"></i>
            <p class="text-gray-500">Chưa có hợp đồng nào</p>
            <p class="text-sm text-gray-400 mt-1">Liên hệ chủ trọ để được hỗ trợ</p>
        </div>
    }
</div>