@model HeThongQuanLyPhongTro.Models.KhachHang

@{
    ViewData["Title"] = "Thêm khách hàng";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
            <h1 class="text-xl font-bold text-white">Thêm khách hàng mới</h1>
            <p class="text-blue-100 text-sm">Nhập thông tin khách hàng</p>
        </div>

        <form asp-action="Create" class="p-6 space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="HoTen" class="block text-sm font-medium text-gray-700 mb-2">Họ tên <span class="text-red-500">*</span></label>
                <input asp-for="HoTen" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập họ tên đầy đủ" />
                <span asp-validation-for="HoTen" class="text-red-500 text-sm"></span>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="SoDienThoai" class="block text-sm font-medium text-gray-700 mb-2">Số điện thoại</label>
                    <input asp-for="SoDienThoai" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="0123456789" />
                    <span asp-validation-for="SoDienThoai" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                    <input asp-for="Email" type="email" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="CCCD" class="block text-sm font-medium text-gray-700 mb-2">CCCD/CMND</label>
                    <input asp-for="CCCD" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="012345678912" />
                    <span asp-validation-for="CCCD" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="NgaySinh" class="block text-sm font-medium text-gray-700 mb-2">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    <span asp-validation-for="NgaySinh" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div>
                <label asp-for="DiaChi" class="block text-sm font-medium text-gray-700 mb-2">Địa chỉ</label>
                <textarea asp-for="DiaChi" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" rows="2" placeholder="Địa chỉ thường trú"></textarea>
                <span asp-validation-for="DiaChi" class="text-red-500 text-sm"></span>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-all">
                    <i class="fas fa-save mr-2"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}