@model HeThongQuanLyPhongTro.Models.Phong

@{
    Layout = null;
    ViewData["Title"] = Model != null ? Model.TenPhong : "Chi tiết phòng";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-100">

    <nav class="bg-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-4 py-3">
            <div class="flex justify-between items-center">
                <a href="@Url.Action("Index", "Home")" class="flex items-center space-x-3">
                    <i class="fas fa-home text-2xl text-blue-500"></i>
                    <span class="text-xl font-bold text-gray-800">Phòng Trọ Xinh</span>
                </a>
                <a href="@Url.Action("Index", "Home")" class="text-gray-600 hover:text-blue-500">
                    <i class="fas fa-arrow-left mr-1"></i> Quay lại
                </a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto px-4 py-8">
        <div class="max-w-4xl mx-auto">
            @if (Model == null)
            {
                <div class="bg-red-100 text-red-700 p-4 rounded-lg text-center">
                    <i class="fas fa-exclamation-triangle text-2xl mb-2"></i>
                    <p>Không tìm thấy thông tin phòng!</p>
                    <a href="@Url.Action("Index", "Home")" class="text-blue-500 hover:underline">Về trang chủ</a>
                </div>
            }
            else
            {
                <div class="bg-white rounded-xl shadow-md overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-500 to-blue-600 h-40 flex items-center justify-center">
                        <i class="fas fa-building text-white text-7xl opacity-50"></i>
                    </div>

                    <div class="p-6">
                        <h1 class="text-2xl font-bold text-gray-800 mb-4">@(Model.TenPhong ?? "Không có tên")</h1>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-gray-500 text-sm">Cơ sở</p>
                                <p class="font-semibold">@(Model.CoSo?.TenCoSo ?? "N/A")</p>
                            </div>
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-gray-500 text-sm">Địa chỉ</p>
                                <p class="font-semibold">@(Model.CoSo?.DiaChi ?? "N/A")</p>
                            </div>
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-gray-500 text-sm">Giá phòng</p>
                                <p class="text-2xl font-bold text-blue-600">@(Model.GiaPhong.ToString("N0")) đ/tháng</p>
                            </div>
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-gray-500 text-sm">Diện tích</p>
                                <p class="font-semibold">@(Model.DienTich.ToString()) m²</p>
                            </div>
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-gray-500 text-sm">Trạng thái</p>
                                @if (Model.TrangThai == "Trống")
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                        <i class="fas fa-check-circle"></i> Còn trống
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs">
                                        <i class="fas fa-lock"></i> Đã thuê
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="mt-6 bg-yellow-50 rounded-lg p-4">
                            <p class="text-yellow-800">
                                <i class="fas fa-phone-alt mr-2"></i>
                                Liên hệ ngay: <strong>0869189018</strong>
                            </p>
                            <p class="text-yellow-800 mt-2">
                                <i class="fas fa-envelope mr-2"></i>
                                Email: <strong>phongtro@gmail.com</strong>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</body>
</html>