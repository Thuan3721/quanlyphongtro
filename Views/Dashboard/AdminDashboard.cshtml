@model HeThongQuanLyPhongTro.Models.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="space-y-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-md border-l-4 border-blue-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Tổng số phòng</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.TongSoPhong</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-building text-blue-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border-l-4 border-green-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Phòng đã thuê</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.SoPhongDaThue</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-door-closed text-green-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border-l-4 border-yellow-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Phòng trống</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.SoPhongTrong</p>
                </div>
                <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-door-open text-yellow-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md border-l-4 border-purple-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Doanh thu tháng @DateTime.Now.Month</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.DoanhThuThangNay.ToString("N0") đ</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-chart-line text-purple-500 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Hợp đồng sắp hết hạn -->
    <div class="bg-white rounded-xl shadow-md p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
            <i class="fas fa-clock text-orange-500 mr-2"></i>
            Hợp đồng sắp hết hạn
        </h3>
        @if (Model.HopDongSapHetHanList.Any())
        {
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Phòng</th>
                            <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Khách hàng</th>
                            <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Ngày kết thúc</th>
                            <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Còn lại</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.HopDongSapHetHanList)
                        {
                            <tr class="border-b">
                                <td class="px-4 py-2">@item.TenPhong</td>
                                <td class="px-4 py-2">@item.TenKhachHang</td>
                                <td class="px-4 py-2">@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                <td class="px-4 py-2 text-red-500 font-medium">@item.SoNgayConLai ngày</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-8 text-gray-500">
                <i class="fas fa-check-circle text-green-500 text-4xl mb-2"></i>
                <p>Không có hợp đồng nào sắp hết hạn!</p>
            </div>
        }
    </div>
    <!-- Thống kê bài đăng -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mt-6">
        <div class="bg-white rounded-xl p-5 shadow-md border-l-4 border-indigo-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Tổng bài đăng</p>
                    <p class="text-3xl font-bold text-gray-800">@Model.TongSoBaiDang</p>
                </div>
                <div class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-newspaper text-indigo-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border-l-4 border-green-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Đang hiển thị</p>
                    <p class="text-3xl font-bold text-green-600">@Model.SoBaiDangHienThi</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-eye text-green-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border-l-4 border-gray-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Đã ẩn</p>
                    <p class="text-3xl font-bold text-gray-600">@Model.SoBaiDangAn</p>
                </div>
                <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-eye-slash text-gray-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-5 shadow-md border-l-4 border-purple-500">
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-gray-500 text-sm">Bài đăng tháng @DateTime.Now.Month</p>
                    <p class="text-3xl font-bold text-purple-600">@Model.SoBaiDangThangNay</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-calendar-alt text-purple-500 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Bài đăng gần đây -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden mt-6">
        <div class="bg-gray-50 px-6 py-3 border-b flex justify-between items-center">
            <h3 class="font-semibold text-gray-700 flex items-center">
                <i class="fas fa-newspaper text-indigo-500 mr-2"></i>
                Bài đăng gần đây
            </h3>
            <a asp-controller="BaiDang" asp-action="Index" class="text-sm text-blue-500 hover:text-blue-700">
                Xem tất cả <i class="fas fa-arrow-right ml-1"></i>
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Tiêu đề</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Phòng</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Ngày đăng</th>
                        <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">Trạng thái</th>
                        <th class="px-4 py-2 text-center text-xs font-medium text-gray-500">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var item in Model.BaiDangGanDayList)
                    {
                        <tr class="hover:bg-gray-50">
                            <td class="px-4 py-2">
                                <span class="font-medium line-clamp-1 max-w-md">@item.TieuDe</span>
                            </td>
                            <td class="px-4 py-2">@item.TenPhong</td>
                            <td class="px-4 py-2">@item.NgayDang.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-2 text-center">
                                @if (item.TrangThai == "Hiển thị")
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                        <i class="fas fa-eye"></i> Hiển thị
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">
                                        <i class="fas fa-eye-slash"></i> Ẩn
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-2 text-center">
                                <a asp-controller="BaiDang" asp-action="Details" asp-route-id="@item.MaBaiDang"
                                   class="text-blue-500 hover:text-blue-700" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.BaiDangGanDayList.Any())
        {
            <div class="text-center py-6">
                <i class="fas fa-newspaper text-gray-300 text-3xl mb-2"></i>
                <p class="text-gray-400">Chưa có bài đăng nào</p>
                <a asp-controller="BaiDang" asp-action="Create" class="inline-block mt-2 text-sm text-blue-500 hover:underline">
                    Đăng bài đầu tiên
                </a>
            </div>
        }
    </div>
    <!-- Quản trị nhanh -->
    @if (ViewBag.Role == "Admin")
    {
        <div class="bg-white rounded-xl shadow-md overflow-hidden mt-6">
            <div class="bg-gray-50 px-6 py-3 border-b">
                <h3 class="font-semibold text-gray-700 flex items-center">
                    <i class="fas fa-cog text-blue-500 mr-2"></i>
                    Quản trị nhanh
                </h3>
            </div>
            <div class="p-5">
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
                    <a asp-controller="CoSo" asp-action="Index"
                       class="bg-blue-500 hover:bg-blue-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-building text-xl block mb-1"></i>
                        <span class="text-xs">Cơ sở</span>
                    </a>
                    <a asp-controller="Phong" asp-action="Index"
                       class="bg-green-500 hover:bg-green-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-door-open text-xl block mb-1"></i>
                        <span class="text-xs">Phòng trọ</span>
                    </a>
                    <a asp-controller="KhachHang" asp-action="Index"
                       class="bg-purple-500 hover:bg-purple-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-users text-xl block mb-1"></i>
                        <span class="text-xs">Khách hàng</span>
                    </a>
                    <a asp-controller="HopDong" asp-action="Index"
                       class="bg-yellow-500 hover:bg-yellow-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-file-contract text-xl block mb-1"></i>
                        <span class="text-xs">Hợp đồng</span>
                    </a>
                    <a asp-controller="HoaDon" asp-action="Index"
                       class="bg-red-500 hover:bg-red-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-receipt text-xl block mb-1"></i>
                        <span class="text-xs">Hóa đơn</span>
                    </a>
                    <a asp-controller="BaiDang" asp-action="Index"
                       class="bg-indigo-500 hover:bg-indigo-600 text-white text-center py-3 px-2 rounded-lg transition-all">
                        <i class="fas fa-newspaper text-xl block mb-1"></i>
                        <span class="text-xs">Bài đăng</span>
                    </a>
                </div>
            </div>
        </div>
    }
</div>