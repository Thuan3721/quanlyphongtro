@{
    ViewData["Title"] = "Trang chủ";
    var khachHang = ViewBag.KhachHang as HeThongQuanLyPhongTro.Models.KhachHang;
    var hopDong = ViewBag.HopDong as HeThongQuanLyPhongTro.Models.HopDong;
}

<div class="space-y-6">
    <!-- Welcome Banner -->
    <div class="bg-gradient-to-r from-blue-500 to-indigo-600 rounded-2xl p-8 text-white shadow-xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold mb-2">Chào mừng @khachHang?.HoTen trở lại! 🏠</h1>
                <p class="text-blue-100">Chúc bạn một ngày mới tốt lành</p>
            </div>
            <div class="text-6xl opacity-20">
                <i class="fas fa-smile-wink"></i>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Phòng đang thuê</p>
                    <p class="text-2xl font-bold text-gray-800">@(hopDong?.PhongNavigation?.TenPhong ?? "Chưa có")</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-door-open text-blue-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Tiền cọc</p>
                    <p class="text-2xl font-bold text-gray-800">@(hopDong?.TienCoc?.ToString("N0") ?? "0") đ</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-money-bill text-green-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Hợp đồng</p>
                    <p class="text-2xl font-bold text-gray-800">@(hopDong != null ? "Hiệu lực" : "Chưa có")</p>
                </div>
                <div class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-file-contract text-yellow-500 text-xl"></i>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-xl transition-all">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm">Thành viên từ</p>
                    <p class="text-2xl font-bold text-gray-800">@(hopDong?.NgayBatDau?.ToString("MM/yyyy") ?? "N/A")</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-calendar text-purple-500 text-xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Thông tin chi tiết -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Thông tin cá nhân -->
        <div class="bg-white rounded-xl shadow-md p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                <i class="fas fa-user-circle text-blue-500 mr-2"></i>
                Thông tin cá nhân
            </h3>
            <div class="space-y-3">
                <div class="flex justify-between py-2 border-b">
                    <span class="text-gray-500">Họ tên:</span>
                    <span class="font-medium">@khachHang?.HoTen</span>
                </div>
                <div class="flex justify-between py-2 border-b">
                    <span class="text-gray-500">Số điện thoại:</span>
                    <span class="font-medium">@khachHang?.SoDienThoai</span>
                </div>
                <div class="flex justify-between py-2 border-b">
                    <span class="text-gray-500">Email:</span>
                    <span class="font-medium">@khachHang?.Email</span>
                </div>
                <div class="flex justify-between py-2 border-b">
                    <span class="text-gray-500">CCCD:</span>
                    <span class="font-medium">@khachHang?.CCCD</span>
                </div>
            </div>
        </div>

        <!-- Thông tin phòng -->
        <div class="bg-white rounded-xl shadow-md p-6">
            <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
                <i class="fas fa-info-circle text-green-500 mr-2"></i>
                Thông tin phòng
            </h3>
            @if (hopDong != null)
            {
                <div class="space-y-3">
                    <div class="flex justify-between py-2 border-b">
                        <span class="text-gray-500">Tên phòng:</span>
                        <span class="font-medium text-blue-600">@hopDong.PhongNavigation?.TenPhong</span>
                    </div>
                    <div class="flex justify-between py-2 border-b">
                        <span class="text-gray-500">Giá phòng:</span>
                        <span class="font-medium">@hopDong.PhongNavigation?.GiaPhong.ToString("N0") đ/tháng</span>
                    </div>
                    <div class="flex justify-between py-2 border-b">
                        <span class="text-gray-500">Diện tích:</span>
                        <span class="font-medium">@hopDong.PhongNavigation?.DienTich m²</span>
                    </div>
                    <div class="flex justify-between py-2 border-b">
                        <span class="text-gray-500">Ngày bắt đầu:</span>
                        <span class="font-medium">@hopDong.NgayBatDau?.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="flex justify-between py-2 border-b">
                        <span class="text-gray-500">Ngày kết thúc:</span>
                        <span class="font-medium text-orange-600">@hopDong.NgayKetThuc?.ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <i class="fas fa-home text-gray-300 text-5xl mb-3"></i>
                    <p class="text-gray-500">Bạn chưa có hợp đồng nào</p>
                    <a href="#" class="inline-block mt-3 text-blue-500 hover:underline">Liên hệ chủ trọ</a>
                </div>
            }
        </div>
    </div>

    <!-- Hóa đơn gần đây -->
    <div class="bg-white rounded-xl shadow-md p-6">
        <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center">
            <i class="fas fa-receipt text-purple-500 mr-2"></i>
            Hóa đơn gần đây
        </h3>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Tháng</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Tổng tiền</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Trạng thái</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-500">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="4" class="text-center py-6 text-gray-500">
                            <i class="fas fa-inbox text-3xl mb-2 block"></i>
                            Chưa có hóa đơn nào
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Animation khi load trang
        document.querySelectorAll('.bg-white').forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
    </script>
}