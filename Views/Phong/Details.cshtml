@model HeThongQuanLyPhongTro.Models.Phong

@{
    ViewData["Title"] = "Chi tiết phòng";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-info-500 to-info-600 px-6 py-4">
            <h1 class="text-xl font-bold text-white">Chi tiết phòng</h1>
            <p class="text-blue-100 text-sm">Thông tin chi tiết của phòng trọ</p>
        </div>

        <div class="p-6">
            <dl class="space-y-3">
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Mã phòng:</dt>
                    <dd class="flex-1">@Model.MaPhong</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Tên phòng:</dt>
                    <dd class="flex-1 font-semibold text-lg">@Model.TenPhong</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Cơ sở:</dt>
                    <dd class="flex-1">@Model.CoSo?.TenCoSo</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Địa chỉ cơ sở:</dt>
                    <dd class="flex-1">@Model.CoSo?.DiaChi</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Giá phòng:</dt>
                    <dd class="flex-1 text-blue-600 font-semibold">@Model.GiaPhong.ToString("N0") đ/tháng</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Diện tích:</dt>
                    <dd class="flex-1">@Model.DienTich m²</dd>
                </div>
                <div class="flex py-2 border-b">
                    <dt class="w-32 font-medium text-gray-600">Trạng thái:</dt>
                    <dd class="flex-1">
                        @if (Model.TrangThai == "Trống")
                        {
                            <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">
                                <i class="fas fa-check-circle"></i> Còn trống
                            </span>
                        }
                        else
                        {
                            <span class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-sm">
                                <i class="fas fa-lock"></i> Đã cho thuê
                            </span>
                        }
                    </dd>
                </div>
            </dl>

            <div class="mt-6 flex justify-end space-x-3 pt-4 border-t">
                <a asp-action="Edit" asp-route-id="@Model.MaPhong" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                    <i class="fas fa-edit mr-2"></i> Sửa
                </a>
                <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
<!-- Thêm vào sau phần thông tin cơ bản -->
<div class="mt-6">
    <div class="border-b">
        <ul class="flex space-x-4">
            <li>
                <button onclick="showTab('info')" id="tabInfo" class="px-4 py-2 text-blue-600 border-b-2 border-blue-600">Thông tin</button>
            </li>
            <li>
                <button onclick="showTab('images')" id="tabImages" class="px-4 py-2 text-gray-500">Hình ảnh</button>
            </li>
            <li>
                <button onclick="showTab('tienich')" id="tabTienich" class="px-4 py-2 text-gray-500">Tiện ích</button>
            </li>
        </ul>
    </div>

    <!-- Tab Thông tin -->
    <div id="infoTab" class="mt-4">
        <!-- Nội dung thông tin phòng hiện tại -->
    </div>

    <!-- Tab Hình ảnh -->
    <div id="imagesTab" class="mt-4 hidden">
        <form asp-action="UploadImage" asp-route-id="@Model.MaPhong" method="post" enctype="multipart/form-data" class="mb-4">
            <div class="flex gap-4">
                <input type="file" name="file" accept="image/*" required class="flex-1 border rounded-lg p-2" />
                <div class="flex items-center">
                    <input type="checkbox" name="isMain" value="true" id="isMain" />
                    <label for="isMain" class="ml-2">Ảnh chính</label>
                </div>
                <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded-lg">Upload</button>
            </div>
        </form>

        <div class="grid grid-cols-3 gap-4">
            @foreach (var image in ViewBag.Images as List<HeThongQuanLyPhongTro.Models.PhongImage> ?? new List<HeThongQuanLyPhongTro.Models.PhongImage>())
            {
                <div class="relative group">
                    <img src="@image.ImagePath" class="w-full h-32 object-cover rounded-lg" />
                    @if (image.IsMain)
                    {
                        <span class="absolute top-2 left-2 bg-yellow-500 text-white text-xs px-2 py-1 rounded">Chính</span>
                    }
                    <form asp-action="DeleteImage" method="post" class="absolute top-2 right-2 hidden group-hover:block">
                        <input type="hidden" name="maImage" value="@image.MaImage" />
                        <input type="hidden" name="maPhong" value="@Model.MaPhong" />
                        <button type="submit" class="bg-red-500 text-white p-1 rounded-full w-6 h-6 flex items-center justify-center">
                            <i class="fas fa-times text-xs"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>

    <!-- Tab Tiện ích -->
    <div id="tienichTab" class="mt-4 hidden">
        <div class="flex justify-between items-center mb-4">
            <p class="text-gray-600">Danh sách tiện ích trong phòng</p>
            <a asp-action="TienIch" asp-route-id="@Model.MaPhong" class="text-blue-500 hover:underline">Quản lý tiện ích</a>
        </div>
        <div class="grid grid-cols-2 gap-2">
            @foreach (var tienIch in ViewBag.TienIchList as List<HeThongQuanLyPhongTro.Models.TienIch> ?? new List<HeThongQuanLyPhongTro.Models.TienIch>())
            {
                <div class="flex items-center text-gray-600">
                    <i class="fas fa-wifi text-green-500 mr-2"></i>
                    <span>@tienIch.TenTienIch (x@tienIch.SoLuong)</span>
                </div>
            }
        </div>
    </div>
</div>

<script>
    function showTab(tabName) {
        document.getElementById('infoTab').classList.add('hidden');
        document.getElementById('imagesTab').classList.add('hidden');
        document.getElementById('tienichTab').classList.add('hidden');

        document.getElementById('tabInfo').classList.remove('text-blue-600', 'border-blue-600');
        document.getElementById('tabImages').classList.remove('text-blue-600', 'border-blue-600');
        document.getElementById('tabTienich').classList.remove('text-blue-600', 'border-blue-600');

        document.getElementById('tabInfo').classList.add('text-gray-500');
        document.getElementById('tabImages').classList.add('text-gray-500');
        document.getElementById('tabTienich').classList.add('text-gray-500');

        if (tabName === 'info') {
            document.getElementById('infoTab').classList.remove('hidden');
            document.getElementById('tabInfo').classList.remove('text-gray-500');
            document.getElementById('tabInfo').classList.add('text-blue-600', 'border-blue-600');
        } else if (tabName === 'images') {
            document.getElementById('imagesTab').classList.remove('hidden');
            document.getElementById('tabImages').classList.remove('text-gray-500');
            document.getElementById('tabImages').classList.add('text-blue-600', 'border-blue-600');
        } else if (tabName === 'tienich') {
            document.getElementById('tienichTab').classList.remove('hidden');
            document.getElementById('tabTienich').classList.remove('text-gray-500');
            document.getElementById('tabTienich').classList.add('text-blue-600', 'border-blue-600');
        }
    }
</script>