@model HeThongQuanLyPhongTro.Models.Phong

@{
    ViewData["Title"] = "Thêm phòng mới";
}

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
            <h1 class="text-xl font-bold text-white">Thêm phòng mới</h1>
            <p class="text-blue-100 text-sm">Nhập thông tin phòng trọ</p>
        </div>

        <form asp-action="Create" class="p-6 space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="MaCoSo" class="block text-sm font-medium text-gray-700 mb-2">Cơ sở <span class="text-red-500">*</span></label>
                <select asp-for="MaCoSo" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Chọn cơ sở --</option>
                    @foreach (var coSo in ViewBag.CoSoList)
                    {
                        <option value="@coSo.MaCoSo">@coSo.TenCoSo</option>
                    }
                </select>
                <span asp-validation-for="MaCoSo" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="TenPhong" class="block text-sm font-medium text-gray-700 mb-2">Tên phòng <span class="text-red-500">*</span></label>
                <input asp-for="TenPhong" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="VD: Phòng 101, Phòng A1..." />
                <span asp-validation-for="TenPhong" class="text-red-500 text-sm"></span>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="GiaPhong" class="block text-sm font-medium text-gray-700 mb-2">Giá phòng (VNĐ/tháng) <span class="text-red-500">*</span></label>
                    <input asp-for="GiaPhong" type="number" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="1.000.000" />
                    <span asp-validation-for="GiaPhong" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="DienTich" class="block text-sm font-medium text-gray-700 mb-2">Diện tích (m²) <span class="text-red-500">*</span></label>
                    <input asp-for="DienTich" type="number" step="0.1" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="25" />
                    <span asp-validation-for="DienTich" class="text-red-500 text-sm"></span>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50 transition-all">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition-all">
                    <i class="fas fa-save mr-2"></i> Lưu
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}