@model IEnumerable<HeThongQuanLyPhongTro.Models.LichSuThuePhong>

@{
    ViewData["Title"] = "Lịch sử thuê phòng";
    var phong = ViewBag.Phong as HeThongQuanLyPhongTro.Models.Phong;
}

<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Lịch sử thuê phòng: @phong?.TenPhong</h1>
                    <p class="text-purple-100 text-sm">Các hợp đồng đã và đang thuê</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-purple-200">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>

        <div class="p-6">
            @if (Model.Any())
            {
                <div class="space-y-4">
                    @foreach (var item in Model)
                    {
                        <div class="border rounded-lg p-4 hover:shadow-md transition-all">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="font-semibold text-gray-800">Khách thuê: @item.TenKhachHang</p>
                                    <p class="text-sm text-gray-500">
                                        Thời gian: @item.NgayBatDau.ToString("dd/MM/yyyy") - @item.NgayKetThuc.ToString("dd/MM/yyyy")
                                    </p>
                                    <p class="text-sm text-gray-500">Giá thuê: @item.GiaPhong.ToString("N0") đ/tháng</p>
                                </div>
                                <div>
                                    @if (item.TrangThai == "Đã kết thúc")
                                    {
                                        <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded-full text-xs">Đã kết thúc</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 bg-green-100 text-green-600 rounded-full text-xs">Đang thuê</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <i class="fas fa-history text-gray-300 text-5xl mb-3"></i>
                    <p class="text-gray-500">Chưa có lịch sử thuê phòng</p>
                </div>
            }
        </div>
    </div>
</div>