@model HeThongQuanLyPhongTro.Models.Phong

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<div class="max-w-lg mx-auto bg-white p-6 rounded shadow mt-10">
    <h2 class="text-2xl font-bold mb-6">Sửa Phòng</h2>

    <form method="post" class="space-y-4">

        <input type="hidden" asp-for="MaPhong" />

        <div>
            <label>Tên Phòng</label>
            <input asp-for="TenPhong" class="w-full border rounded px-3 py-2" />
            <span asp-validation-for="TenPhong" class="text-red-500"></span>
        </div>

        <div>
            <label>Giá Phòng</label>
            <input asp-for="GiaPhong" class="w-full border rounded px-3 py-2" />
            <span asp-validation-for="GiaPhong" class="text-red-500"></span>
        </div>

        <div>
            <label>Diện Tích</label>
            <input asp-for="DienTich" class="w-full border rounded px-3 py-2" />
            <span asp-validation-for="DienTich" class="text-red-500"></span>
        </div>

        <div>
            <label>Trạng Thái</label>
            <select asp-for="TrangThai" class="w-full border rounded px-3 py-2">
                <option value="Trống">Trống</option>
                <option value="Đã thuê">Đã thuê</option>
                <option value="Sửa chữa">Sửa chữa</option>
            </select>
            <span asp-validation-for="TrangThai" class="text-red-500"></span>
        </div>

        <button type="submit"
                class="bg-blue-500 text-white px-4 py-2 rounded">
            Cập Nhật
        </button>
    </form>
</div>