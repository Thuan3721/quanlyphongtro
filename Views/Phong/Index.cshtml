@model IEnumerable<HeThongQuanLyPhongTro.Models.Phong>

@{
    ViewData["Title"] = "Quản lý phòng trọ";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Quản lý phòng trọ</h1>
            <p class="text-gray-500 mt-1">Quản lý danh sách các phòng trọ</p>
        </div>
        <a asp-action="Create" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-all flex items-center">
            <i class="fas fa-plus mr-2"></i> Thêm phòng mới
        </a>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded">
            <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded">
            <i class="fas fa-exclamation-circle mr-2"></i> @TempData["Error"]
        </div>
    }

    <!-- Search and Filter -->
    <div class="bg-white rounded-xl shadow-md p-4">
        <form method="get" class="flex gap-4">
            <div class="flex-1">
                <input type="text" name="searchString" value="@ViewBag.SearchString"
                       placeholder="Tìm kiếm theo tên phòng..."
                       class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <select name="trangThai" class="px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                    @foreach (var item in ViewBag.TrangThaiList)
                    {
                        if (ViewBag.TrangThai == item)
                        {
                            <option value="@item" selected>@item</option>
                        }
                        else
                        {
                            <option value="@item">@item</option>
                        }
                    }
                </select>
            </div>
            <div>
                <button type="submit" class="bg-blue-500 text-white px-6 py-2 rounded-lg hover:bg-blue-600 transition-all">
                    <i class="fas fa-search mr-2"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mã phòng</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tên phòng</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cơ sở</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Giá phòng</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Diện tích</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Trạng thái</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-all">
                            <td class="px-6 py-4">@item.MaPhong</td>
                            <td class="px-6 py-4 font-medium">@item.TenPhong</td>
                            <td class="px-6 py-4">@item.CoSo?.TenCoSo</td>
                            <td class="px-6 py-4">@item.GiaPhong.ToString("N0") đ</td>
                            <td class="px-6 py-4">@item.DienTich m²</td>
                            <td class="px-6 py-4">
                                @if (item.TrangThai == "Trống")
                                {
                                    <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs font-semibold">
                                        <i class="fas fa-check-circle"></i> Trống
                                    </span>
                                }
                                else
                                {
                                    <span class="px-2 py-1 bg-red-100 text-red-700 rounded-full text-xs font-semibold">
                                        <i class="fas fa-lock"></i> Đã thuê
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex space-x-2">
                                    <a asp-action="Details" asp-route-id="@item.MaPhong"
                                       class="text-blue-500 hover:text-blue-700" title="Chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.MaPhong"
                                       class="text-yellow-500 hover:text-yellow-700" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.MaPhong"
                                       class="text-red-500 hover:text-red-700" title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-12">
                <i class="fas fa-inbox text-gray-300 text-5xl mb-3"></i>
                <p class="text-gray-500">Không có dữ liệu phòng trọ</p>
                <a asp-action="Create" class="inline-block mt-3 text-blue-500 hover:underline">Thêm phòng đầu tiên</a>
            </div>
        }
    </div>
</div>
<div class="flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Quản lý phòng trọ</h1>
        <p class="text-gray-500 mt-1">Quản lý danh sách các phòng trọ</p>
    </div>
    <div class="flex space-x-3">
        <a asp-action="ExportExcel" class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition-all flex items-center">
            <i class="fas fa-file-excel mr-2"></i> Export Excel
        </a>
        <a asp-action="Create" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-all flex items-center">
            <i class="fas fa-plus mr-2"></i> Thêm phòng mới
        </a>
    </div>
</div>