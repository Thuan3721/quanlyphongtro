@model List<HeThongQuanLyPhongTro.Models.Phong>
<form method="get" class="flex gap-4 mb-4">

    <input type="text"
           name="searchString"
           placeholder="Tìm tên phòng..."
           class="border px-3 py-2 rounded" />

    <select name="trangThai"
            class="border px-3 py-2 rounded">
        <option value="">Tất cả trạng thái</option>
        <option value="Trống">Trống</option>
        <option value="Đã thuê">Đã thuê</option>
        <option value="Sửa chữa">Sửa chữa</option>
    </select>

    <button type="submit"
            class="bg-green-500 text-white px-4 py-2 rounded">
        Tìm Kiếm
    </button>

</form>
<div class="max-w-6xl mx-auto mt-10 bg-white p-6 rounded shadow">

    <div class="flex justify-between items-center mb-4">
        <h2 class="text-2xl font-bold">Danh Sách Phòng</h2>

        <a href="/Phong/Create"
           class="bg-blue-500 text-white px-4 py-2 rounded">
           Thêm Phòng
        </a>
    </div>

    <table class="table-auto w-full border border-gray-300">
        <tr class="bg-gray-100">
            <th class="border px-4 py-2">Mã</th>
            <th class="border px-4 py-2">Tên Phòng</th>
            <th class="border px-4 py-2">Giá</th>
            <th class="border px-4 py-2">Diện Tích</th>
            <th class="border px-4 py-2">Trạng Thái</th>
            <th class="border px-4 py-2">Thao Tác</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td class="border px-4 py-2">@item.MaPhong</td>
                <td class="border px-4 py-2">@item.TenPhong</td>
                <td class="border px-4 py-2">@item.GiaPhong</td>
                <td class="border px-4 py-2">@item.DienTich</td>
                <td class="border px-4 py-2">@item.TrangThai</td>
                <td class="border px-4 py-2 space-x-2">
                    <a href="/Phong/Edit/@item.MaPhong"
                       class="bg-yellow-500 text-white px-3 py-1 rounded">
                       Sửa
                    </a>

                    <a href="/Phong/Delete/@item.MaPhong"
                       onclick="return confirm('Bạn có chắc muốn xóa phòng này?')"
                       class="bg-red-500 text-white px-3 py-1 rounded">
                       Xóa
                    </a>
                </td>
            </tr>
        }
    </table>

</div>