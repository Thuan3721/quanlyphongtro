@model HeThongQuanLyPhongTro.Models.BaiDang

@{
    ViewData["Title"] = "Đăng tin mới";
    var phongList = ViewBag.PhongList as List<HeThongQuanLyPhongTro.Models.Phong>;
}

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
            <h1 class="text-xl font-bold text-white">Đăng tin cho thuê</h1>
            <p class="text-blue-100 text-sm">Tạo bài đăng mới để thu hút khách thuê</p>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="p-6 space-y-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="MaPhong" class="block text-sm font-medium text-gray-700 mb-2">Chọn phòng <span class="text-red-500">*</span></label>
                <select asp-for="MaPhong" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                    <option value="">-- Chọn phòng --</option>
                    @foreach (var phong in phongList ?? new List<HeThongQuanLyPhongTro.Models.Phong>())
                    {
                        <option value="@phong.MaPhong">
                            @phong.TenPhong - @phong.CoSo?.TenCoSo - @phong.GiaPhong.ToString("N0") đ/tháng
                        </option>
                    }
                </select>
                <span asp-validation-for="MaPhong" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="TieuDe" class="block text-sm font-medium text-gray-700 mb-2">Tiêu đề <span class="text-red-500">*</span></label>
                <input asp-for="TieuDe" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                       placeholder="VD: Cho thuê phòng trọ đẹp, đầy đủ tiện nghi" />
                <span asp-validation-for="TieuDe" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="MoTa" class="block text-sm font-medium text-gray-700 mb-2">Mô tả chi tiết</label>
                <textarea asp-for="MoTa" rows="6" class="w-full px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                          placeholder="Mô tả chi tiết về phòng trọ, tiện ích, vị trí, giá cả..."></textarea>
                <span asp-validation-for="MoTa" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Hình ảnh</label>
                <input type="file" name="fileAnh" accept="image/*" class="w-full px-3 py-2 border rounded-lg" />
                <p class="text-xs text-gray-500 mt-1">Chấp nhận file: JPG, JPEG, PNG, GIF</p>
            </div>

            <div class="bg-yellow-50 p-4 rounded-lg">
                <div class="flex items-start">
                    <i class="fas fa-info-circle text-yellow-500 mt-1 mr-3"></i>
                    <div class="text-sm text-yellow-700">
                        <p class="font-semibold">Lưu ý:</p>
                        <ul class="list-disc list-inside mt-1">
                            <li>Bài đăng sẽ được hiển thị ngay sau khi tạo</li>
                            <li>Có thể ẩn/hiện bài đăng sau khi tạo</li>
                            <li>Chỉ hiển thị các phòng đang trống</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <a asp-action="Index" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Hủy</a>
                <button type="submit" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                    <i class="fas fa-paper-plane mr-2"></i> Đăng tin
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}