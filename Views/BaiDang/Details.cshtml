@model HeThongQuanLyPhongTro.Models.BaiDang

@{
    ViewData["Title"] = "Chi tiết bài đăng";
}

<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-xl shadow-md overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold text-white">Chi tiết bài đăng</h1>
                    <p class="text-indigo-100">Mã bài đăng: BD@Model.MaBaiDang</p>
                </div>
                <a asp-action="Index" class="text-white hover:text-indigo-200 transition-all">
                    <i class="fas fa-arrow-left mr-2"></i> Quay lại
                </a>
            </div>
        </div>

        <div class="p-6">
            <!-- Ảnh bài đăng -->
            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                <div class="mb-6">
                    <img src="@Model.HinhAnh" alt="@Model.TieuDe" class="w-full rounded-lg object-cover max-h-96">
                </div>
            }

            <!-- Thông tin bài đăng -->
            <div class="bg-gray-50 rounded-lg p-5 mb-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <p class="text-gray-500 text-sm">Tiêu đề</p>
                        <p class="font-semibold text-lg">@Model.TieuDe</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Trạng thái</p>
                        @if (Model.TrangThai == "Hiển thị")
                        {
                            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                <i class="fas fa-eye"></i> Hiển thị
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">
                                <i class="fas fa-eye-slash"></i> Ẩn
                            </span>
                        }
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Phòng</p>
                        <p class="font-semibold">@Model.PhongNavigation?.TenPhong</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Cơ sở</p>
                        <p class="font-semibold">@Model.PhongNavigation?.CoSo?.TenCoSo</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Địa chỉ</p>
                        <p class="font-semibold">@Model.PhongNavigation?.CoSo?.DiaChi</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Ngày đăng</p>
                        <p class="font-semibold">@Model.NgayDang?.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Giá phòng</p>
                        <p class="font-semibold text-blue-600">@Model.PhongNavigation?.GiaPhong.ToString("N0") đ/tháng</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-sm">Diện tích</p>
                        <p class="font-semibold">@Model.PhongNavigation?.DienTich m²</p>
                    </div>
                </div>
            </div>

            <!-- Mô tả -->
            <div class="mb-6">
                <h3 class="font-semibold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-align-left text-indigo-500 mr-2"></i>
                    Mô tả chi tiết
                </h3>
                <div class="bg-white border rounded-lg p-4">
                    <p class="text-gray-700 whitespace-pre-line">@Model.MoTa</p>
                </div>
            </div>

            <!-- Nút thao tác -->
            <div class="flex justify-end space-x-3 pt-4 border-t">
                <a asp-action="Edit" asp-route-id="@Model.MaBaiDang" class="px-4 py-2 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 transition-all">
                    <i class="fas fa-edit mr-2"></i> Chỉnh sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.MaBaiDang" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 transition-all">
                    <i class="fas fa-trash mr-2"></i> Xóa
                </a>
            </div>
        </div>
    </div>
</div>