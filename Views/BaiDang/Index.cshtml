@model IEnumerable<HeThongQuanLyPhongTro.Models.BaiDang>

@{
    ViewData["Title"] = "Quản lý bài đăng";
}

<div class="space-y-6">
    <div class="flex justify-between items-center flex-wrap gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Quản lý bài đăng</h1>
            <p class="text-gray-500 mt-1">Đăng tin cho thuê phòng trọ</p>
        </div>
        <a asp-action="Create" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-all">
            <i class="fas fa-plus mr-2"></i> Đăng tin mới
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded">
            <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
        </div>
    }

    <!-- Bộ lọc -->
    <div class="bg-white rounded-xl shadow-md p-4">
        <form method="get" class="flex gap-3">
            <input type="text" name="searchString" value="@ViewBag.SearchString"
                   placeholder="Tìm theo tiêu đề, tên phòng..."
                   class="flex-1 px-3 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">

            <select name="trangThai" class="px-3 py-2 border rounded-lg">
                @foreach (var item in ViewBag.TrangThaiList)
                {
                    if (ViewBag.TrangThai == item)
                    {
                        <option value="@item" selected>@item</option>
                    }
                    else
                    {
                        <option value="@item">@item</option>
                    }
                }
            </select>

            <button type="submit" class="bg-blue-500 text-white px-4 py-2 rounded-lg">
                <i class="fas fa-search mr-2"></i> Tìm kiếm
            </button>
        </form>
    </div>

    <!-- Danh sách bài đăng dạng card -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-all">
                @if (!string.IsNullOrEmpty(item.HinhAnh))
                {
                    <img src="@item.HinhAnh" alt="@item.TieuDe" class="w-full h-48 object-cover">
                }
                else
                {
                    <div class="w-full h-48 bg-gray-200 flex items-center justify-center">
                        <i class="fas fa-image text-gray-400 text-5xl"></i>
                    </div>
                }

                <div class="p-4">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-lg text-gray-800 line-clamp-1">@item.TieuDe</h3>
                        @if (item.TrangThai == "Hiển thị")
                        {
                            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">
                                <i class="fas fa-eye"></i> Hiển thị
                            </span>
                        }
                        else
                        {
                            <span class="px-2 py-1 bg-gray-100 text-gray-700 rounded-full text-xs">
                                <i class="fas fa-eye-slash"></i> Ẩn
                            </span>
                        }
                    </div>

                    <p class="text-gray-500 text-sm mb-2">
                        <i class="fas fa-building mr-1"></i> @item.PhongNavigation?.TenPhong
                        (@item.PhongNavigation?.CoSo?.TenCoSo)
                    </p>

                    <p class="text-gray-600 text-sm line-clamp-2 mb-3">@item.MoTa</p>

                    <div class="flex justify-between items-center text-xs text-gray-400 mb-3">
                        <span><i class="fas fa-calendar-alt mr-1"></i> @item.NgayDang?.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    <div class="flex justify-between items-center">
                        <div class="flex space-x-2">
                            <a asp-action="Details" asp-route-id="@item.MaBaiDang"
                               class="text-blue-500 hover:text-blue-700" title="Chi tiết">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.MaBaiDang"
                               class="text-yellow-500 hover:text-yellow-700" title="Sửa">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaBaiDang"
                               class="text-red-500 hover:text-red-700" title="Xóa">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>

                        <button onclick="toggleTrangThai(@item.MaBaiDang, this)"
                                class="text-sm @(item.TrangThai == "Hiển thị" ? "text-orange-500" : "text-green-500") hover:opacity-70">
                            @if (item.TrangThai == "Hiển thị")
                            {
                                <text><i class="fas fa-eye-slash mr-1"></i> Ẩn tin</text>
                            }
                            else
                            {
                                <text><i class="fas fa-eye mr-1"></i> Hiện tin</text>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white rounded-xl shadow-md p-12 text-center">
            <i class="fas fa-newspaper text-gray-300 text-5xl mb-3"></i>
            <p class="text-gray-500">Chưa có bài đăng nào</p>
            <a asp-action="Create" class="inline-block mt-3 text-blue-500 hover:underline">Đăng tin đầu tiên</a>
        </div>
    }
</div>

<script>
    function toggleTrangThai(id, btn) {
        fetch(`@Url.Action("ToggleTrangThai", "BaiDang")?id=${id}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                if (data.trangThai === 'Hiển thị') {
                    btn.innerHTML = '<i class="fas fa-eye-slash mr-1"></i> Ẩn tin';
                    btn.classList.remove('text-green-500');
                    btn.classList.add('text-orange-500');
                } else {
                    btn.innerHTML = '<i class="fas fa-eye mr-1"></i> Hiện tin';
                    btn.classList.remove('text-orange-500');
                    btn.classList.add('text-green-500');
                }
                location.reload();
            }
        });
    }
</script>