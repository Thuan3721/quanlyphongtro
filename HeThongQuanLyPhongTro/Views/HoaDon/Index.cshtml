@model IEnumerable<HeThongQuanLyPhongTro.Models.HoaDon>

@{
    ViewData["Title"] = "Danh sách hóa đơn";
}

<h2>Danh sách hóa đơn</h2>

<p><a asp-action="Create" class="btn btn-primary">Tạo hóa đơn mới</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Mã hóa đơn</th>
            <th>Mã hợp đồng</th>
            <th>Tháng</th>
            <th>Năm</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Ngày thanh toán</th>
            <th>Ngày tạo</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.MaHoaDon</td>
            <td>@item.MaHopDong</td>
            <td>@item.Thang</td>
            <td>@item.Nam</td>
            <td>@item.TongTien.ToString("N0")</td>
            <td>@item.TrangThaiThanhToan</td>
            <td>@(item.NgayThanhToan?.ToString("yyyy-MM-dd"))</td>
            <td>@item.NgayTao.ToString("yyyy-MM-dd")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Xem</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Xóa hóa đơn này?');">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>
