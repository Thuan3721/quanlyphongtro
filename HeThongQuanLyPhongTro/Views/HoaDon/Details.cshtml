@model HeThongQuanLyPhongTro.Models.HoaDon

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}

<h2>Chi tiết hóa đơn</h2>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.MaHoaDon</h5>
        <p class="card-text">Mã hợp đồng: @Model.MaHopDong</p>
        <p class="card-text">Kỳ: @Model.Thang/@Model.Nam</p>
        <p class="card-text">Tổng tiền: @Model.TongTien.ToString("N0") VNĐ</p>
        <p class="card-text">Trạng thái: @Model.TrangThaiThanhToan</p>
        <p class="card-text">Ngày thanh toán: @(Model.NgayThanhToan?.ToString("yyyy-MM-dd"))</p>
        <p class="card-text">Nội dung: @Model.NoiDungThanhToan</p>
        <p class="card-text">Ngày tạo: @Model.NgayTao.ToString("yyyy-MM-dd HH:mm")</p>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-success">In / Xuất PDF</a>
    </div>
</div>
