@model IEnumerable<HeThongQuanLyPhongTro.Models.NguoiOhopDong>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.HoTen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Cccd)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoDienThoai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LaNguoiDaiDien)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaHopDongNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.HoTen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Cccd)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SoDienThoai)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LaNguoiDaiDien)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaHopDongNavigation.MaHopDong)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MaNguoiO">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MaNguoiO">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MaNguoiO">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
