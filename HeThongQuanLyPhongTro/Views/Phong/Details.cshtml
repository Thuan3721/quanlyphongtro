@model HeThongQuanLyPhongTro.Models.Phong

@{
    ViewData["Title"] = "Chi tiết phòng";
}

<h2>Chi tiết phòng</h2>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.TenPhong (@Model.MaPhong)</h5>
        <p class="card-text">Số người tối đa: @Model.SoLuongToiDa</p>
        <p class="card-text">Diện tích: @Model.DienTich m²</p>
        <p class="card-text">Giá: @Model.Gia.ToString("N0") VNĐ</p>
        <p class="card-text">Tình trạng: @Model.TinhTrang</p>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
