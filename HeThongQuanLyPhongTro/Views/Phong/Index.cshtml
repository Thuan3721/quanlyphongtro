@model IEnumerable<HeThongQuanLyPhongTro.Models.Phong>

@{
    ViewData["Title"] = "Danh sách phòng";
}

<h2>Danh sách phòng</h2>

<p><a asp-action="Create" class="btn btn-primary">Tạo phòng mới</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Tên</th>
            <th>SL tối đa</th>
            <th>Diện tích</th>
            <th>Giá</th>
            <th>Tình trạng</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.MaPhong</td>
            <td>@item.TenPhong</td>
            <td>@item.SoLuongToiDa</td>
            <td>@item.DienTich</td>
            <td>@item.Gia.ToString("N0")</td>
            <td>@item.TinhTrang</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Xem</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Xóa phòng này?');">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>
