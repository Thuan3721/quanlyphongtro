@model HeThongQuanLyPhongTro.Models.Phong

<div class="mb-3">
    <label asp-for="MaPhong" class="form-label"></label>
    <input asp-for="MaPhong" class="form-control" />
    <span asp-validation-for="MaPhong" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="TenPhong" class="form-label"></label>
    <input asp-for="TenPhong" class="form-control" />
    <span asp-validation-for="TenPhong" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="SoLuongToiDa" class="form-label"></label>
    <input asp-for="SoLuongToiDa" class="form-control" type="number" />
    <span asp-validation-for="SoLuongToiDa" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="DienTich" class="form-label"></label>
    <input asp-for="DienTich" class="form-control" type="number" step="0.1" />
    <span asp-validation-for="DienTich" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Gia" class="form-label"></label>
    <input asp-for="Gia" class="form-control" type="number" step="1000" />
    <span asp-validation-for="Gia" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="TinhTrang" class="form-label"></label>
    <select asp-for="TinhTrang" class="form-select">
        <option value="">-- Chọn tình trạng --</option>
        <option>Trống</option>
        <option>Đã thuê</option>
        <option>Bảo trì</option>
    </select>
    <span asp-validation-for="TinhTrang" class="text-danger"></span>
</div>
