@model IEnumerable<HeThongQuanLyPhongTro.Models.HopDong>

@{
    ViewData["Title"] = "Danh sách hợp đồng";
}

<h2>Danh sách hợp đồng</h2>

<p><a asp-action="Create" class="btn btn-primary">Tạo hợp đồng mới</a></p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Mã hợp đồng</th>
            <th>Mã khách hàng</th>
            <th>Mã phòng</th>
            <th>Ngày bắt đầu</th>
            <th>Ngày kết thúc</th>
            <th>Tiền cọc</th>
            <th>Thời hạn (tháng)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.MaHopDong</td>
            <td>@item.MaKhachHang</td>
            <td>@item.MaPhong</td>
            <td>@item.NgayBatDau.ToString("yyyy-MM-dd")</td>
            <td>@(item.NgayKetThuc?.ToString("yyyy-MM-dd"))</td>
            <td>@item.TienCoc.ToString("N0")</td>
            <td>@item.ThoiHan</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Xem</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('Xóa hợp đồng này?');">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>
